# Copy to %USERPROFILE%\.vans_coding_router\fly.secrets.env and fill in values.
# Save as UTF-8 **without BOM** (VS Code: bottom-right encoding → Save with Encoding).
# Then: powershell -ExecutionPolicy Bypass -File scripts\deploy-fly.ps1

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
OLLAMA_CLOUD_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
