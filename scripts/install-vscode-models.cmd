@echo off
chcp 65001 >nul
powershell -NoProfile -ExecutionPolicy Bypass -Command "$raw = Get-Content -LiteralPath '%~f0' -Raw; $b64 = ($raw -split '(?m)^:VANS_PAYLOAD\r?\n', 2)[1].Trim(); $path = Join-Path $env:TEMP 'vans-install-vscode-models.ps1'; [IO.File]::WriteAllBytes($path, [Convert]::FromBase64String($b64)); powershell -NoProfile -ExecutionPolicy Bypass -File $path; exit $LASTEXITCODE"
if errorlevel 1 pause
exit /b
:VANS_PAYLOAD

